# crisAI environment configuration
# Copy this file to `.env` and fill in the values you need.
# Do not commit your real `.env` file or any live credentials.

# --- Model provider credentials ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Default runtime model ---
# Used as a general default where applicable.
CRISAI_DEFAULT_MODEL=gpt-5.4-mini

# --- OpenAI Agents SDK (optional) ---
# Set to true to stop sending traces to OpenAI (no effect on crisAI JSONL trace files).
# OPENAI_AGENTS_DISABLE_TRACING=true

# --- MCP stdio clients (optional) ---
# Seconds for MCP session requests (list_tools, tool calls). Heavy servers (SharePoint) need more than the SDK default of 5.
# CRISAI_MCP_CLIENT_TIMEOUT_SECONDS=60

# --- Local paths ---
# These may be absolute paths or paths relative to the repository root.
CRISAI_WORKSPACE_DIR=./workspace
CRISAI_LOG_DIR=./logs
CRISAI_REGISTRY_DIR=./registry

# --- Optional SharePoint / Microsoft Entra settings ---
# Enable these only if you are using the SharePoint integration.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_TOKEN_CACHE_PATH=.tokens/msal_token_cache.json

# Optional defaults for SharePoint discovery
MS_GRAPH_SCOPES=User.Read,Files.Read.All,Sites.Read.All

# --- Intranet and peer workflow tuning ---
# Intranet page catalogue cache TTL (hours) for intranet_list_all_pages
INTRANET_PAGE_CACHE_TTL_HOURS=4

# Peer mode: max extra refiner/judge rounds after initial judge pass
CRISAI_PEER_MAX_REFINEMENT_ROUNDS=2

# Peer mode: max structural escalation attempts (author/challenger rerun)
# when revise loops remain unresolved
CRISAI_PEER_MAX_ESCALATIONS=1
