# crisAI environment configuration
# Copy this file to `.env` and fill in the values you need.
# Do not commit your real `.env` file or any live credentials.

# --- Model provider credentials ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Default runtime model ---
# Used as a general default where applicable.
CRISAI_DEFAULT_MODEL=gpt-5.4-mini

# --- Local paths ---
# These may be absolute paths or paths relative to the repository root.
CRISAI_WORKSPACE_DIR=./workspace
CRISAI_LOG_DIR=./logs
CRISAI_REGISTRY_DIR=./registry

# --- Optional SharePoint / Microsoft Entra settings ---
# Enable these only if you are using the SharePoint integration.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_TOKEN_CACHE_PATH=.tokens/msal_token_cache.json

# Optional defaults for SharePoint discovery
MS_GRAPH_SCOPES=User.Read,Files.Read.All,Sites.Read.All
